# ─────────────────────────────────────────────────
# Swing Screener Pro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ─────────────────────────────────────────────────

# Reddit API (PRAW)
# Créer une app sur https://www.reddit.com/prefs/apps  (type : script)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SwingScreenerBot/1.0 by YourUsername

# Twitter / X API v2  (plan Basic minimum requis pour la recherche)
# Créer un projet sur https://developer.twitter.com/
X_BEARER_TOKEN=your_x_bearer_token
